{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MQL5",
  "scopeName": "source.mql5",
  "fileTypes": ["mq5", "mqh"],
  "patterns": [
    { "include": "#preprocessor" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#storage-modifiers" },
    { "include": "#event-handlers" },
    { "include": "#builtin-functions" },
    { "include": "#builtin-constants" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.include.mql5",
          "match": "^\\s*(#include)\\s*([<\"].*?[>\"])",
          "captures": {
            "1": { "name": "keyword.control.directive.include.mql5" },
            "2": { "name": "string.quoted.other.include.mql5" }
          }
        },
        {
          "name": "meta.preprocessor.define.mql5",
          "match": "^\\s*(#define)\\s+(\\w+)",
          "captures": {
            "1": { "name": "keyword.control.directive.define.mql5" },
            "2": { "name": "entity.name.constant.preprocessor.mql5" }
          }
        },
        {
          "name": "keyword.control.directive.property.mql5",
          "match": "^\\s*#property\\b.*$"
        },
        {
          "name": "keyword.control.directive.import.mql5",
          "match": "^\\s*(#import)\\b.*$"
        },
        {
          "name": "keyword.control.directive.mql5",
          "match": "^\\s*(#ifdef|#ifndef|#else|#endif|#undef)\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mql5",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mql5",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.mql5" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.mql5" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mql5",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.mql5", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.mql5",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.mql5",
          "match": "\\b[0-9]+\\.[0-9]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.mql5",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mql5",
          "match": "\\b(if|else|for|while|do|switch|case|default|break|continue|return)\\b"
        },
        {
          "name": "keyword.operator.new.mql5",
          "match": "\\b(new|delete|sizeof|this)\\b"
        },
        {
          "name": "keyword.other.mql5",
          "match": "\\b(class|struct|interface|enum|template|namespace|typedef)\\b"
        },
        {
          "name": "constant.language.boolean.mql5",
          "match": "\\b(true|false|NULL|INVALID_HANDLE|WHOLE_ARRAY|EMPTY|EMPTY_VALUE)\\b"
        }
      ]
    },
    "types": {
      "name": "storage.type.mql5",
      "match": "\\b(void|bool|char|uchar|short|ushort|int|uint|long|ulong|float|double|string|datetime|color|object)\\b"
    },
    "storage-modifiers": {
      "name": "storage.modifier.mql5",
      "match": "\\b(public|private|protected|static|const|extern|input|sinput|virtual|override|final|explicit|inline)\\b"
    },
    "event-handlers": {
      "name": "entity.name.function.event-handler.mql5",
      "match": "\\b(OnInit|OnDeinit|OnTick|OnStart|OnCalculate|OnTimer|OnTrade|OnTradeTransaction|OnBookEvent|OnChartEvent|OnTester|OnTesterInit|OnTesterDeinit|OnTesterPass)\\b"
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.trading.mql5",
          "match": "\\b(OrderSend|OrderSendAsync|OrderCheck|OrderCalcMargin|OrderCalcProfit|PositionOpen|PositionClose|PositionModify|PositionGetDouble|PositionGetInteger|PositionGetString|PositionGetSymbol|PositionGetTicket|PositionSelect|PositionSelectByTicket|PositionsTotal|OrderGetDouble|OrderGetInteger|OrderGetString|OrderGetTicket|OrderSelect|OrdersTotal|HistoryDealGetDouble|HistoryDealGetInteger|HistoryDealGetString|HistoryDealSelect|HistoryDealsTotal|HistoryOrderGetDouble|HistoryOrderGetInteger|HistoryOrderGetString|HistoryOrderSelect|HistoryOrdersTotal|HistorySelect|HistorySelectByPosition)\\b"
        },
        {
          "name": "support.function.market.mql5",
          "match": "\\b(SymbolInfoDouble|SymbolInfoInteger|SymbolInfoString|SymbolInfoTick|SymbolInfoSessionQuote|SymbolInfoSessionTrade|SymbolSelect|SymbolIsSynchronized|SymbolsTotal|SymbolName|MarketBookAdd|MarketBookRelease|MarketBookGet)\\b"
        },
        {
          "name": "support.function.rates.mql5",
          "match": "\\b(CopyRates|CopyTime|CopyOpen|CopyHigh|CopyLow|CopyClose|CopyTickVolume|CopyRealVolume|CopySpread|CopyBufValue|CopyTicks|CopyTicksRange)\\b"
        },
        {
          "name": "support.function.indicator.mql5",
          "match": "\\b(IndicatorCreate|IndicatorRelease|IndicatorParameters|IndicatorSetDouble|IndicatorSetInteger|IndicatorSetString|IndicatorShortName|SetIndexBuffer|PlotIndexSetDouble|PlotIndexSetInteger|PlotIndexSetString|iMA|iRSI|iMACD|iBands|iADX|iATR|iStochastic|iCCI|iMomentum|iWPR|iSAR|iAlligator|iBearsPower|iBullsPower|iChaikin|iDEMA|iDPO|iForce|iFractals|iFrAMA|iGator|iIchimoku|iMFI|iOBV|iOsMA|iRVI|iStdDev|iTriX|iUltimateOscillator|iVolumes|iBWMFI|iCustom)\\b"
        },
        {
          "name": "support.function.account.mql5",
          "match": "\\b(AccountInfoDouble|AccountInfoInteger|AccountInfoString)\\b"
        },
        {
          "name": "support.function.terminal.mql5",
          "match": "\\b(TerminalInfoDouble|TerminalInfoInteger|TerminalInfoString)\\b"
        },
        {
          "name": "support.function.time.mql5",
          "match": "\\b(TimeCurrent|TimeLocal|TimeGMT|TimeTradeServer|TimeToStruct|StructToTime|TimeDay|TimeDayOfWeek|TimeDayOfYear|TimeHour|TimeMinute|TimeMonth|TimeSeconds|TimeYear)\\b"
        },
        {
          "name": "support.function.math.mql5",
          "match": "\\b(MathAbs|MathArccos|MathArcsin|MathArctan|MathCeil|MathCos|MathExp|MathFloor|MathLog|MathLog10|MathMax|MathMin|MathMod|MathPow|MathRand|MathRound|MathSin|MathSqrt|MathSrand|MathTan|MathIsValidNumber)\\b"
        },
        {
          "name": "support.function.string.mql5",
          "match": "\\b(StringLen|StringSubstr|StringFind|StringReplace|StringFormat|StringToDouble|StringToInteger|StringToTime|StringToUpper|StringToLower|StringTrimLeft|StringTrimRight|StringConcatenate|StringCompare|StringContains|StringSplit|StringAdd|StringFill|StringGetCharacter|StringSetCharacter|StringInit|StringBufferLen|StringToCharArray|CharArrayToString|CharToString)\\b"
        },
        {
          "name": "support.function.array.mql5",
          "match": "\\b(ArraySize|ArrayResize|ArraySetAsSeries|ArrayIsSeries|ArraySort|ArrayBsearch|ArrayCopy|ArrayFill|ArrayInitialize|ArrayFree|ArrayGetAsSeries|ArrayMaximum|ArrayMinimum|ArrayRange|ArrayDimension|ArraySwap)\\b"
        },
        {
          "name": "support.function.print.mql5",
          "match": "\\b(Print|PrintFormat|Alert|Comment|MessageBox|PlaySound|SendMail|SendNotification|SendFTP)\\b"
        },
        {
          "name": "support.function.chart.mql5",
          "match": "\\b(ChartOpen|ChartClose|ChartFirst|ChartNext|ChartId|ChartSymbol|ChartPeriod|ChartSetDouble|ChartSetInteger|ChartSetString|ChartGetDouble|ChartGetInteger|ChartGetString|ChartNavigate|ChartRedraw|ChartScreenShot|ChartTimePriceToXY|ChartXYToTimePrice|ChartWindowFind|ChartWindowOnDropped|ChartPriceOnDropped|ChartTimeOnDropped|ChartXOnDropped|ChartYOnDropped|ObjectCreate|ObjectDelete|ObjectFind|ObjectGetDouble|ObjectGetInteger|ObjectGetString|ObjectGetTimeByValue|ObjectGetValueByTime|ObjectMove|ObjectName|ObjectSetDouble|ObjectSetInteger|ObjectSetString|ObjectsDeleteAll|ObjectsTotal|ObjectType)\\b"
        },
        {
          "name": "support.function.convert.mql5",
          "match": "\\b(NormalizeDouble|DoubleToString|IntegerToString|TimeToString|EnumToString|ColorToString|StringToColor|StringToEnum)\\b"
        },
        {
          "name": "support.function.file.mql5",
          "match": "\\b(FileOpen|FileClose|FileDelete|FileMove|FileCopy|FileFlush|FileGetInteger|FileIsEnding|FileIsLineEnding|FileIsExist|FileReadArray|FileReadBool|FileReadDatetime|FileReadDouble|FileReadFloat|FileReadInteger|FileReadLong|FileReadNumber|FileReadString|FileReadStruct|FileSeek|FileSize|FileTell|FileWrite|FileWriteArray|FileWriteDouble|FileWriteFloat|FileWriteInteger|FileWriteLong|FileWriteString|FileWriteStruct|FolderCreate|FolderDelete|FolderClean)\\b"
        }
      ]
    },
    "builtin-constants": {
      "patterns": [
        {
          "name": "constant.language.timeframe.mql5",
          "match": "\\b(PERIOD_M1|PERIOD_M2|PERIOD_M3|PERIOD_M4|PERIOD_M5|PERIOD_M6|PERIOD_M10|PERIOD_M12|PERIOD_M15|PERIOD_M20|PERIOD_M30|PERIOD_H1|PERIOD_H2|PERIOD_H3|PERIOD_H4|PERIOD_H6|PERIOD_H8|PERIOD_H12|PERIOD_D1|PERIOD_W1|PERIOD_MN1|PERIOD_CURRENT)\\b"
        },
        {
          "name": "constant.language.order-type.mql5",
          "match": "\\b(ORDER_TYPE_BUY|ORDER_TYPE_SELL|ORDER_TYPE_BUY_LIMIT|ORDER_TYPE_SELL_LIMIT|ORDER_TYPE_BUY_STOP|ORDER_TYPE_SELL_STOP|ORDER_TYPE_BUY_STOP_LIMIT|ORDER_TYPE_SELL_STOP_LIMIT|ORDER_TYPE_CLOSE_BY)\\b"
        },
        {
          "name": "constant.language.trade-action.mql5",
          "match": "\\b(TRADE_ACTION_DEAL|TRADE_ACTION_PENDING|TRADE_ACTION_SLTP|TRADE_ACTION_MODIFY|TRADE_ACTION_REMOVE|TRADE_ACTION_CLOSE_BY)\\b"
        },
        {
          "name": "constant.language.position.mql5",
          "match": "\\b(POSITION_TYPE_BUY|POSITION_TYPE_SELL)\\b"
        },
        {
          "name": "constant.language.init-reason.mql5",
          "match": "\\b(INIT_SUCCEEDED|INIT_FAILED|INIT_PARAMETERS_INCORRECT|INIT_AGENT_NOT_SUITABLE)\\b"
        },
        {
          "name": "constant.language.symbol-info.mql5",
          "match": "\\b(SYMBOL_ASK|SYMBOL_BID|SYMBOL_POINT|SYMBOL_DIGITS|SYMBOL_SPREAD|SYMBOL_VOLUME_MIN|SYMBOL_VOLUME_MAX|SYMBOL_VOLUME_STEP|SYMBOL_TRADE_CONTRACT_SIZE|SYMBOL_MARGIN_INITIAL|SYMBOL_MARGIN_MAINTENANCE)\\b"
        },
        {
          "name": "constant.language.apply-to.mql5",
          "match": "\\b(PRICE_CLOSE|PRICE_OPEN|PRICE_HIGH|PRICE_LOW|PRICE_MEDIAN|PRICE_TYPICAL|PRICE_WEIGHTED)\\b"
        },
        {
          "name": "constant.language.ma-method.mql5",
          "match": "\\b(MODE_SMA|MODE_EMA|MODE_SMMA|MODE_LWMA)\\b"
        },
        {
          "name": "constant.language.draw.mql5",
          "match": "\\b(DRAW_NONE|DRAW_LINE|DRAW_SECTION|DRAW_HISTOGRAM|DRAW_HISTOGRAM2|DRAW_ARROW|DRAW_ZIGZAG|DRAW_FILLING|DRAW_BARS|DRAW_CANDLES|DRAW_COLOR_LINE|DRAW_COLOR_SECTION|DRAW_COLOR_HISTOGRAM|DRAW_COLOR_HISTOGRAM2|DRAW_COLOR_ARROW|DRAW_COLOR_ZIGZAG|DRAW_COLOR_BARS|DRAW_COLOR_CANDLES)\\b"
        },
        {
          "name": "constant.language.clr.mql5",
          "match": "\\b(clrRed|clrGreen|clrBlue|clrWhite|clrBlack|clrYellow|clrOrange|clrPurple|clrAqua|clrLime|clrSilver|clrGray|clrNavy|clrTeal|clrGold|clrCoral|clrCrimson|clrDarkBlue|clrDarkGreen|clrDarkRed|clrNONE)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.mql5",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.mql5",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.mql5",
          "match": "(&|\\||\\^|~|<<|>>)"
        },
        {
          "name": "keyword.operator.assignment.mql5",
          "match": "(=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)"
        },
        {
          "name": "keyword.operator.arithmetic.mql5",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.mql5",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  }
}
