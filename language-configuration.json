{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^((?!.*\\/\\*).*\\*\\/)?[^{]*\\{[^}\"']*$",
    "decreaseIndentPattern": "^(.*\\*\\/)?\\s*\\}"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "onEnterRules": [
    {
      "beforeText": "^\\s*\\/\\*\\*(?!\\/)([^\\*]|\\*(?!\\/))*$",
      "action": { "indentAction": "indent", "appendText": " * " }
    },
    {
      "beforeText": "^\\s* \\*[^/]*$",
      "action": { "indentAction": "none", "appendText": "* " }
    },
    {
      "beforeText": "^\\s* \\*/\\s*$",
      "action": { "indentAction": "outdent" }
    }
  ]
}
